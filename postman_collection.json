    {
      "name": "✅ Task",
      "item": [
        {
          "name": "1. Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data._id) {",
                  "  pm.collectionVariables.set('TASK_ID', res.data._id);",
                  "}"
