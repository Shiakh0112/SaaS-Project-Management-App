              "mode": "raw",
              "raw": "{\n  \"title\": \"Login page banana hai\",\n  \"description\": \"JWT auth ke saath login page\",\n  \"boardId\": \"{{BOARD_ID}}\",\n  \"listId\": \"{{LIST_ID}}\",\n  \"priority\": \"high\",\n  \"dueDate\": \"2025-12-31\",\n  \"assignees\": [\"{{USER_ID}}\"]\n}"
            }
          }
        },
        {
          "name": "2. Get Tasks By Board",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{BASE_URL}}/api/tasks/{{BOARD_ID}}"
          }
        },
