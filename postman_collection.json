{
  "info": {
    "name": "SaaS Project Management API",
    "description": "Sare API endpoints ke test cases - Auth se lekar Subscription tak",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:5000" },
    { "key": "TOKEN", "value": "" },
    { "key": "REFRESH_TOKEN", "value": "" },
    { "key": "USER_ID", "value": "" },
    { "key": "TEAM_ID", "value": "" },
    { "key": "PROJECT_ID", "value": "" },
    { "key": "BOARD_ID", "value": "" },
    { "key": "LIST_ID", "value": "" },
    { "key": "TASK_ID", "value": "" },
    { "key": "NOTIFICATION_ID", "value": "" },
    { "key": "INVITE_TOKEN", "value": "" },
    { "key": "RESET_TOKEN", "value": "" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "1. Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@gmail.com\",\n  \"password\": \"Test@1234\"\n}"
            }
          }
        },
        {
          "name": "2. Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/api/auth/send-otp",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@gmail.com\"\n}"
            }
          }
        },
        {
          "name": "3. Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/api/auth/verify-otp",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@gmail.com\",\n  \"otp\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "4. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('TOKEN', res.data.accessToken);",
                  "  pm.collectionVariables.set('REFRESH_TOKEN', res.data.refreshToken);",
                  "  pm.collectionVariables.set('USER_ID', res.data.user._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@gmail.com\",\n  \"password\": \"Test@1234\"\n}"
            }
          }
        },
        {
          "name": "5. Google Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/api/auth/google-login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"<google_id_token_here>\"\n}"
            }
          }
        },
        {
          "name": "6. Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('TOKEN', res.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/api/auth/refresh-token",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{REFRESH_TOKEN}}\"\n}"
            }
          }
        },
        {
          "name": "7. Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/api/auth/forgot-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@gmail.com\"\n}"
            }
          }
        },
        {
          "name": "8. Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/api/auth/reset-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{RESET_TOKEN}}\",\n  \"password\": \"NewPass@1234\"\n}"
            }
          }
        },
        {
          "name": "9. Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "url": "{{BASE_URL}}/api/auth/logout"
          }
        }
      ]
    },

    {
      "name": "👤 User",
      "item": [
        {
          "name": "1. Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{BASE_URL}}/api/users/me"
          }
        },
        {
          "name": "2. Update Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{BASE_URL}}/api/users/update-profile",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Updated Name", "type": "text" },
                { "key": "avatar", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "3. Get User By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{BASE_URL}}/api/users/{{USER_ID}}"
          }
        }
      ]
    },

    {
      "name": "👥 Team",
      "item": [
        {
          "name": "1. Create Team",
          "event": [
            {
              "listen": "test",
              "script": {
